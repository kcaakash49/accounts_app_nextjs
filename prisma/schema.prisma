// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id            Int          @id @default(autoincrement())
  name          String
  contact       String       @unique
  secondContact String?
  address       String?
  activeStatus  ActiveStatus @default(ONLINE)
  status        DueStatus    @default(UNPAID)
  createdAt     DateTime     @default(now())
  dueDate       DateTime?
  sales         Sales[] // All dues recorded for the customer
  payments      Payment[]
  // All payments made by the customer
}

model Sales {
  id          Int       @id @default(autoincrement())
  customer    Customer  @relation(fields: [customerId], references: [id])
  customerId  Int
  amount      Float
  note        String?
  createdAt   DateTime  @default(now())
}

model Payment {
  id            Int           @id @default(autoincrement())
  customer      Customer      @relation(fields: [customerId], references: [id])
  customerId    Int
  amountPaid    Float
  paymentMethod PaymentMethod
  paidAt        DateTime      @default(now())
  note          String?

  recordedBy  AdminUser @relation(fields: [adminUserId], references: [id])
  adminUserId Int
}

model AdminUser {
  id            Int            @id @default(autoincrement())
  name          String
  username      String         @unique
  password      String
  createdAt     DateTime       @default(now())
  expenses      Expenses[]
  payments      Payment[]
  trashPayments TrashPayment[]
  stockOperations StockLog[]
}

model Expenses {
  id          Int       @id @default(autoincrement())
  amount      Float
  title       String
  expenseType String
  note        String
  quantity    Int       @default(1)
  total       Float     @default(0)
  recordedBy  AdminUser @relation(fields: [adminUserId], references: [id])
  adminUserId Int
  createdAt   DateTime  @default(now())
}

model TrashCustomer {
  id           Int            @id @default(autoincrement())
  name         String
  contact      String
  address      String?
  activeStatus ActiveStatus
  status       DueStatus
  createdAt    DateTime
  deletedAt    DateTime       @default(now())
  dueDate      DateTime?
  sales        TrashSales[]
  payments     TrashPayment[]
}

model TrashSales {
  id              Int           @id @default(autoincrement())
  trashCustomer   TrashCustomer @relation(fields: [trashCustomerId], references: [id])
  trashCustomerId Int
  amount          Float
  note            String?
  createdAt       DateTime
}

model TrashPayment {
  id              Int           @id @default(autoincrement())
  trashCustomer   TrashCustomer @relation(fields: [trashCustomerId], references: [id])
  trashCustomerId Int
  amountPaid      Float
  paymentMethod   PaymentMethod
  paidAt          DateTime
  note            String?
  recordedBy      AdminUser     @relation(fields: [adminUserId], references: [id])
  adminUserId     Int
}


//IMS
model Vendor {
  id        String    @id @default(uuid())
  name      String
  address   String
  vatNumber String?   // Optional VAT / PAN Number
  contact   String
  email     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  StockBatchTable[] // One-to-many relationship with items they supply
  
  @@map("vendors")
}

// ==========================================
// CATEGORY MANAGEMENT
// ==========================================
model Category {
  id          String    @id @default(uuid())
  name        String    @unique // e.g., "Fiber Cable", "Drop Cable", "ONU"
  slug        String    @unique // e.g., "fiber-cable", "drop-cable"
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

// ==========================================
// PRODUCT & INVENTORY MANAGEMENT
// ==========================================
model Product {
  id          String   @id @default(uuid())
  sku         String   @unique // Stock Keeping Unit for unique identification
  name        String   // e.g., "12 Core ADSS Fiber Cable"
  minStock    Int      @default(5) // Low stock alert threshold
  specs       Json     @default("{}") 
  // Relations
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  // Tracking adjustments
  batches      StockBatchTable[]
  stockHistory StockLog[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("products")
}

model StockBatchTable{
  id String @id @default(uuid())
  batch String
  productId String
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity Int
  costPrice   Decimal  @db.Decimal(10, 2)
  vendorId String
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ==========================================
// INVENTORY AUDIT TRAILS (Crucial for IMS)
// ==========================================
enum StockAction {
  INWARD  // Stock added via purchase
  OUTWARD // Stock consumed / assigned to customer
  RETURN  // Returned items
  ADJUSTMENT // Manual audit correction
}

model StockLog {
  id          String      @id @default(uuid())
  productId   String
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int         // Quantity changed (e.g., +500 or -20)
  action      StockAction
  referenceId String?     // e.g., SaleId or PurchaseOrderId for cross-referencing
  note        String?     // e.g., "Assigned to customer order #230"
  performedById Int      // User ID or name who tracked it
  performedBy AdminUser @relation(fields: [performedById], references: [id])      // For simplicity, storing as string (e.g., "admin" or "user123")
  createdAt   DateTime    @default(now())

  @@map("stock_logs")
}

enum DueStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMethod {
  ONLINE
  CASH
}

enum SalesStatus {
  PAID
  UNPAID
}

enum ActiveStatus {
  ONLINE
  EXPIRED
}
